{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rune-kit.github.io/rune/config-schema.json",
  "title": "Rune project configuration",
  "description": "Schema for rune.config.json generated by @rune-kit/rune.",
  "type": "object",
  "required": [
    "version",
    "platform"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URL used by editors for validation and completion."
    },
    "version": {
      "const": 1,
      "description": "Rune configuration format version."
    },
    "platform": {
      "type": "string",
      "enum": [
        "claude",
        "cursor",
        "windsurf",
        "antigravity",
        "generic",
        "openclaw",
        "codex",
        "opencode",
        "aider",
        "copilot",
        "gemini",
        "qoder",
        "qwen"
      ],
      "description": "Compiler adapter target."
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "default": "@rune-kit/rune",
      "description": "Rune package marker or path to a Rune source checkout."
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disabled": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": [],
          "description": "Core skill names excluded from compilation."
        }
      },
      "default": {
        "disabled": []
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "Extension packs to compile; null enables every discovered pack.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          ],
          "default": null
        }
      },
      "default": {
        "enabled": null
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "index": {
          "type": "boolean",
          "default": true,
          "description": "Emit skill-index.json with the compiled output."
        }
      },
      "default": {
        "index": true
      }
    },
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pro": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute path, or project-relative path, to the Pro extensions directory."
        },
        "business": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute path, or project-relative path, to the Business extensions directory."
        }
      },
      "description": "Optional paid-tier extension sources used during compilation."
    }
  },
  "examples": [
    {
      "$schema": "https://rune-kit.github.io/rune/config-schema.json",
      "version": 1,
      "platform": "codex",
      "source": "@rune-kit/rune",
      "skills": {
        "disabled": []
      },
      "extensions": {
        "enabled": null
      },
      "output": {
        "index": true
      },
      "tiers": {
        "pro": "../Pro/extensions",
        "business": "../Business/extensions"
      }
    }
  ]
}
