{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rune-kit.github.io/rune/schemas/hooks-manifest.v1.json",
  "title": "Rune Paid-Tier Hooks Manifest",
  "description": "Declares paid-tier lifecycle hooks and platform fallbacks consumed by Rune Free setup.",
  "type": "object",
  "required": ["name", "tier", "version", "minFreeVersion", "requires", "entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tier": {
      "enum": ["pro", "business"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "minFreeVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hookEntry"
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "hookEntry": {
      "type": "object",
      "required": ["id", "skill", "event", "command", "description", "platforms"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "event": {
          "type": "string",
          "minLength": 1
        },
        "matcher": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "async": {
          "type": "boolean"
        },
        "padding": {
          "type": "integer",
          "minimum": 0
        },
        "claudeOnly": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "globs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "platforms": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  }
}
